# ─────────────────────────────────────────────────────────────────────────────
# Festa POS runs in one of two modes, chosen by NEXT_PUBLIC_APP_MODE.
#
#   local  (DEFAULT) — single device, no backend. Everything is stored on the
#                      device (localStorage), seeded from lib/demo-data.ts.
#                      Needs ZERO config: just `pnpm dev` or deploy the static
#                      build. Nothing below is required.
#
#   shared           — multiple devices share one dataset via Supabase, with an
#                      automatic fall back to the local store if it's unreachable.
#                      Requires the NEXT_PUBLIC_SUPABASE_* vars below.
#
# Anything other than "shared" (including unset) means local.
# ─────────────────────────────────────────────────────────────────────────────

# NEXT_PUBLIC_APP_MODE=shared

# Show the demo account codes on the login screen, so anyone can sign in without
# knowing a real PIN. Always on in local mode; in shared mode it only reveals the
# PUBLIC demo PINs (1234 / 5678), never a real operator's bcrypt-hashed PIN.
# Leave UNSET in a real shared production deploy with real operators.
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true

# ── Shared mode only ─────────────────────────────────────────────────────────
# Local Supabase (after `pnpm supabase:start`, run `pnpm supabase:env-sync`).
# Ports match supabase/config.toml and lib/local-supabase.ts (not default 54321).
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54621
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Hosted Supabase (production shared deploy) — replace with your project values:
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Local dev tools (optional — not used by the Next.js app)
# SUPABASE_STUDIO_URL=http://127.0.0.1:54623
# SUPABASE_INBUCKET_URL=http://127.0.0.1:54624
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54622/postgres
