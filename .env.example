# Copy to .env.local for local dev (after `pnpm supabase:start`):
#   pnpm supabase:env-sync
#
# Ports match supabase/config.toml and lib/local-supabase.ts (not default 54321/54323).

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54621
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Show the demo account codes on the login screen, so anyone who clones and
# launches the app can sign in without knowing a real PIN. This only ever reveals
# the PUBLIC demo PINs baked into lib/demo-data.ts (1234 / 5678) — never a real
# operator's PIN, which is a bcrypt hash the browser never sees. The codes also
# appear automatically whenever the app is in demo mode (Supabase paused).
# Leave this UNSET (or "false") in a real production deploy with real operators.
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true

# Local dev tools (optional — not used by the Next.js app)
# SUPABASE_STUDIO_URL=http://127.0.0.1:54623
# SUPABASE_INBUCKET_URL=http://127.0.0.1:54624
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54622/postgres

# Hosted Supabase (GitLab Pages / production) — replace with your project values:
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
